# Xero OAuth2 credentials
# Get these from https://developer.xero.com/myapps
XERO_CLIENT_ID=your_client_id_here
XERO_CLIENT_SECRET=your_client_secret_here
XERO_REDIRECT_URI=http://localhost:3000/auth/callback

# Xero Webhook signing key
# Found in your Xero app settings under Webhooks
XERO_WEBHOOK_KEY=your_webhook_key_here

# Express session secret — use a long random string in production
SESSION_SECRET=change-me-in-production

# Server
PORT=3000
NODE_ENV=development
